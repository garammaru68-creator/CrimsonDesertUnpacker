			<UIView id="TimerHud"					layer="30"	filename="UI/GameMain/Play/TimerHud.html" tag2="hud-info minigame"/>
			<UIView id="WarningTimerPanel"			layer="30"	filename="UI/GameMain/Play/WarningTimerPanel.html" tag2="hud-play minigame"/>
