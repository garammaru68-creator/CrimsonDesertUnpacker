		<ViewContext id="Play">

			<UIView id="GameTitle"					layer="1"	filename="UI/GameMain/Title/TitleView.html" tag2="title loading"/>

			<!-- <UIView id="CharacterListView"			layer="1"	filename="UI/GameMain/CharacterManagement/CharacterListView.html" tag2="characterselect"/> -->

			<UIView id="GameLoading"				layer="1"	filename="UI/GameMain/Loading/GameLoadingView.html" tag2="loading gamedataloading clientgameplaytemp"/><!--clientgameplaytemp 변경 될 Tag 사용 금지-->

			<!-- 240523 Layer 순으로 정리 -->
			<!--: UIView(View)들이 기본적으로 absolute가 아니어서 layer=""를 줍니다. layer 번호 순서에 따라 layering이 됩니다. -->

			<!-- HUD_Play : hud 게이지 종류를 모아놓은 view -->
			<UIView id="StatusGaugeView"			layer="10"	filename="UI/GameMain/Play/StatusGaugeView2.html" tag2="hud-play"/>
			<!-- HUD_Play : 미니맵 -->
			<UIView id="MinimapView"				layer="10"	filename="UI/GameMain/Play/MinimapHudView2.html" tag2="hud-play"/>
			<!-- HUD_Play : 수동,자동 실행 되는 HUD -->
			<UIView id="HudView"					layer="10"	filename="UI/GameMain/Play/HudView2.html" tag2="hud-play minigame"/>
			<!-- HUD_Play : 다른 UI들보다 위로 보여주기 위해서 추가 Panel Layer 순이 높음 -->
			<UIView id="HudOverPanel"				layer="30"	filename="UI/GameMain/Play/HudOverPanel.html" tag2="hud-play"/>
			<!-- Gauge 패널  -->
			<UIView id="GaugePanel"					layer="10"	filename="UI/GameMain/Play/GaugePanel.html" tag2="dialog hud-play hud-info"/>

			<!-- 말풍선 UI  -->
			<UIView id="SubtitleTagView"			layer="20"	filename="UI/GameMain/Play/SubtitleTagView.html" tag2="dialog hud-play"/>

			<!-- Interaction : 타겟 인터렉션 UI -->
			<UIView id="InteractionPanel"			layer="20"	filename="UI/GameMain/Play/InteractionPanel.html" ignoreCulling="true" tag2="interaction"/>
			
			<!-- HUD_Play : 크로스 헤어 -->
			<UIView id="CrossHairAutoTargetingView"	layer="30"	filename="UI/GameMain/Play/CrossHairAutoTargetingView.html" tag2="hud-play minigame gimmick"/>

			<!-- HUD_Play : indicator 패널 -->
			<UIView id="WarningIndicatorView"		layer="30"	filename="UI/GameMain/Play/WarningIndicatorView.html" tag2="hud-play minigame"/>
			
			<!-- HUD_Info : 표지판 이정표 -->
			<!-- <UIView id="MilePostView"				layer="30"	filename="UI/GameMain/Play/MilePostView.html" tag2="hud-info"/> -->
